# Forzar LF en scripts de shell para que funcionen en Linux sin conversión
*.sh        text eol=lf
*.py        text eol=lf
*.qss       text eol=lf
*.json      text eol=lf
*.md        text eol=lf
*.conf      text eol=lf
*.service   text eol=lf
*.timer     text eol=lf
*.v4        text eol=lf
*.ipset     text eol=lf

# Windows batch (CRLF)
*.bat       text eol=crlf
